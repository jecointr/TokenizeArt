# Copy this file to `.env` and fill in your own values.
# Never commit your real `.env` file — it holds a private key.

# RPC endpoint for Sepolia (leave empty to use the default public one).
# For better reliability, use Alchemy or Infura: https://www.alchemy.com/
SEPOLIA_RPC=https://rpc.sepolia.org

# Private key of the wallet that will deploy and mint (needs SepoliaETH from faucet).
# Format: 0x-prefixed 64 hex chars.
PRIVATE_KEY=0xyourprivatekeyhere

# Optional: Etherscan API key, used only if you want to run `hardhat verify`.
ETHERSCAN_API_KEY=

# Address of the already-deployed contract (filled in after `npm run deploy`).
CONTRACT_ADDRESS=

# IPFS URI of the token metadata JSON (filled in after uploading to IPFS/Pinata).
# Example: ipfs://bafybeigdyr.../metadata.json
TOKEN_URI=

# Address that should receive the freshly minted NFT (defaults to the deployer).
MINT_TO=

# --- Bonus: fully on-chain variant (TokenizeArt42OnChain) ---
ONCHAIN_CONTRACT_ADDRESS=
